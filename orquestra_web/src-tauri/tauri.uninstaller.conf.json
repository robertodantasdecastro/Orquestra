{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orquestra Uninstaller",
  "version": "0.2.0",
  "identifier": "com.localrag.orquestra.uninstaller",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 4177",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:4177",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Orquestra Uninstaller",
        "width": 1180,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orquestra AI",
  "version": "0.2.0",
  "identifier": "com.localrag.orquestra",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 4177",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:4177",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Orquestra AI",
        "width": 1520,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"]
  }
}
